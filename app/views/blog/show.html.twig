{% extends "partials/blog.html.twig" %}

{% set postTitle = ('Blog #' ~ (post.id) ~ ': "' ~ (post.title) ~ '"')%}
{% set postDate = "published at " ~ (post.datePublished | date('H:i')) ~ " on " ~ (post.datePublished | date('Y-m-d'))%}

{% set pageTitle = (post.title|capitalize) %}

{% block blogContent %}
    {{ post.content }}
{% endblock %}